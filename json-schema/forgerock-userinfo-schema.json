{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/UserInfo",
  "title": "UserInfo",
  "type": "object",
  "description": "OpenID Connect UserInfo claims",
  "properties": {
    "sub": {
      "type": "string",
      "description": "Subject identifier"
    },
    "name": {
      "type": "string"
    },
    "given_name": {
      "type": "string"
    },
    "family_name": {
      "type": "string"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "email_verified": {
      "type": "boolean"
    },
    "phone_number": {
      "type": "string"
    },
    "address": {
      "type": "object",
      "properties": {
        "formatted": {
          "type": "string"
        }
      }
    }
  }
}